{
  "name": "eficenza360",
  "private": true,
  "packageManager": "npm@10.9.0",
  "version": "0.0.0",
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:all": "docker-compose up -d && turbo run dev",
    "db:up": "docker-compose up -d db redis",
    "lint": "turbo run lint",
    "slint": "npm run lint",
    "test": "turbo run test",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "turbo": "latest"
  },
  "dependencies": {
    "@azure/ai-form-recognizer": "^5.1.0",
    "@azure/identity": "^4.13.0",
    "@azure/keyvault-secrets": "^4.10.0",
    "@azure/storage-blob": "^12.30.0",
    "pino": "^10.2.0",
    "pino-pretty": "^13.1.3"
  }
}
