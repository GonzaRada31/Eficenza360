# Eficenza 360 - Common Variables
APP_NAME=Eficenza360
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

# Database Variables
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/eficenza?schema=public

# Queue / Cache Mechanism
REDIS_URL=redis://localhost:6379

# Security Configurations
JWT_SECRET=changeme_to_a_minimum_64_byte_random_string_in_production

# Cloud Storage (Azure Blob Storage)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_BLOB_CONTAINER=eficenza-documents

# Legacy S3 Config (If still active)
S3_ENDPOINT=https://s3.amazonaws.com
S3_ACCESS_KEY=mock_access_key
S3_SECRET=mock_secret_key
S3_BUCKET_NAME=eficenza-documents-dev
S3_REGION=us-east-1

# Observability
OTEL_ENABLED=true
OTEL_SERVICE_NAME=eficenza-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Billing Integrations
STRIPE_SECRET_KEY=sk_test_mock_secret_key
