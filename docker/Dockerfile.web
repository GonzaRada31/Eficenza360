FROM node:20-alpine AS builder

WORKDIR /app

# Enable corepack
RUN corepack enable

# Copy root configurations
COPY package.json package-lock.json turbo.json ./

# Copy apps and packages
COPY apps/api ./apps/api/
COPY apps/client ./apps/client/

# Install dependencies
RUN npm ci

# Build the Frontend
RUN npm run build --workspace=apps/client

# -----------------
# Nginx Server
# -----------------
FROM nginx:alpine AS runner

# Remove default nginx static assets
RUN rm -rf /usr/share/nginx/html/*

# Copy static build from builder
COPY --from=builder /app/apps/client/dist /usr/share/nginx/html

# Copy custom nginx configuration if needed
# COPY docker/nginx.conf /etc/nginx/conf.d/default.conf

# Security headers configuration snippet can be added to standard nginx conf via sed or copying full conf.
# For simplicity, default works for the static serving of Vite SPA.
# If SPA routing is needed, add an SPA generic config.
RUN echo 'server { \
    listen       80; \
    server_name  localhost; \
    location / { \
    root   /usr/share/nginx/html; \
    index  index.html index.htm; \
    try_files $uri $uri/ /index.html; \
    } \
    }' > /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
